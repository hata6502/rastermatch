{
  "name": "rasterdiff",
  "version": "1.0.5",
  "license": "CC0-1.0",
  "author": "hata6502",
  "type": "module",
  "bin": {
    "rasterdiff": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:css && npm run build:app && npm run build:cli",
    "build:css": "npx tailwindcss -i src/index.css -o docs/index.css --minify",
    "build:app": "esbuild src/app.tsx --bundle --format=esm --minify --outfile=docs/app.js",
    "build:cli": "tsc",
    "test": "tsc --noEmit",
    "start": "http-server -c-1 docs"
  },
  "devDependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "clsx": "^2.1.1",
    "diff": "^8.0.3",
    "esbuild": "^0.25.0",
    "http-server": "^14.1.1",
    "jimp": "^1.6.1",
    "pdfjs-dist": "^4.9.155",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
